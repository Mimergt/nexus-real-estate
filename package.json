{
  "name": "nexus-re",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "lint:web": "npm run lint -w web",
    "dev:api": "npm run dev -w @nexus-re/api",
    "build:api": "npm run build -w @nexus-re/api",
    "typecheck:api": "npm run typecheck -w @nexus-re/api"
  },
  "engines": {
    "node": ">=22"
  }
}